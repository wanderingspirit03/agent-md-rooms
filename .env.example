# Same-origin hosted deploy.
# Set this to the public HTTPS URL users and agents open.
FOLD_PUBLIC_URL=

# Split deploys only: use these instead of FOLD_PUBLIC_URL when the web app
# and append-log sync server are on different origins.
FOLD_PUBLIC_APP_URL=
FOLD_PUBLIC_SYNC_URL=
NEXT_PUBLIC_FOLD_SYNC_URL=

# Hosted persistence. Point this at a mounted volume/disk when available.
FOLD_DATA_DIR=./data/append-log

# Most platforms provide PORT automatically.
PORT=3000
